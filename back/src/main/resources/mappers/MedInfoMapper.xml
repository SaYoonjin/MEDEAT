<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.medeat.medical.dao.MedInfoDao">

    <insert id="insert" parameterType="com.medeat.medical.dto.MedInfoDto">
        INSERT INTO med_info (user_id, disease, medicine)
        VALUES (#{userId}, #{disease}, #{medicine})
    </insert>

</mapper>