<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.medeat.medical.dao.DiseaseDao">

	<!-- 전체 질병 목록 조회 -->
	<select id="getAllDiseases"
	        resultType="com.medeat.medical.dto.DiseaseDto">
	    SELECT disease_id AS diseaseId,
	           disease_name AS diseaseName
	    FROM disease
	    ORDER BY disease_name
	</select>
	
    <!-- 자동완성 검색 -->
    <select id="searchDisease" parameterType="string" resultType="com.medeat.medical.dto.DiseaseDto">
        SELECT disease_id AS diseaseId,
               disease_name AS diseaseName
        FROM disease
        WHERE disease_name LIKE CONCAT('%', #{keyword}, '%')
        ORDER BY disease_name
    </select>

    <!-- 사용자 질병 목록 조회 -->
    <select id="getUserDiseaseList"
            parameterType="long"
            resultType="com.medeat.medical.dto.DiseaseDto">

        SELECT ud.user_disease_id AS userDiseaseId,
               d.disease_id AS diseaseId,
               d.disease_name AS diseaseName
        FROM user_disease ud
        JOIN disease d ON ud.disease_id = d.disease_id
        WHERE ud.user_id = #{userId}
        ORDER BY d.disease_name
    </select>

    <!-- 이름으로 조회 -->
    <select id="findByName" parameterType="string" resultType="com.medeat.medical.dto.DiseaseDto">
        SELECT disease_id AS diseaseId,
               disease_name AS diseaseName
        FROM disease
        WHERE disease_name = #{name}
    </select>

    <!-- 새로운 질병 추가 -->
    <insert id="insertDisease" parameterType="string">
        INSERT INTO disease (disease_name)
        VALUES (#{name})
    </insert>

    <select id="getLastInsertedId" resultType="long">
        SELECT LAST_INSERT_ID()
    </select>

    <!-- 사용자에게 질병 매핑 -->
    <insert id="insertUserDisease">
        INSERT INTO user_disease (user_id, disease_id)
        VALUES (#{userId}, #{diseaseId})
    </insert>

    <!-- 사용자 질병 삭제 -->
    <delete id="deleteDisease" parameterType="long">
	    DELETE FROM user_disease
	    WHERE user_disease_id = #{value}
	</delete>

	<select id="countUserDisease" resultType="int">
	    SELECT COUNT(*)
	    FROM user_disease
	    WHERE user_id = #{userId}
	      AND disease_id = #{diseaseId}
	</select>

</mapper>
